[
  {
    "id": "preset-005",
    "title": "Stir-fried Oil Gluten with Vegetables",
    "zh_title": "素炒油面筋",
    "image_key": "stir_fried_oil_gluten",
    "ingredients": [
      { "en": "Oil Gluten", "zh": "油面筋", "category": "Other" },
      { "en": "Shiitake Mushroom", "zh": "香菇", "category": "Vegetable" },
      { "en": "Carrot", "zh": "胡萝卜", "category": "Vegetable" },
      { "en": "Black Fungus", "zh": "黑木耳", "category": "Vegetable" },
      { "en": "Bamboo Shoot", "zh": "春笋", "category": "Vegetable" },
      { "en": "Green Onion", "zh": "小葱", "category": "Vegetable" },
      { "en": "Oyster Sauce", "zh": "蚝油", "category": "Seasoning and herbs" },
      { "en": "Light Soy Sauce", "zh": "生抽", "category": "Seasoning and herbs" },
      { "en": "Dark Soy Sauce", "zh": "老抽", "category": "Seasoning and herbs" },
      { "en": "Sugar", "zh": "白糖", "category": "Other" },
      { "en": "Pepper Powder", "zh": "胡椒粉", "category": "Seasoning and herbs" },
      { "en": "Cornstarch", "zh": "淀粉", "category": "Other" }
    ],
    "steps": [
      "油面筋和木耳提前泡软捞出沥干；香菇、春笋、胡萝卜切片或块备用；小葱切段。",
      "准备料汁：将蚝油、生抽、老抽、白糖、胡椒粉、淀粉和50毫升水混合均匀。",
      "锅中烧水，香菇焯水1分钟，春笋和胡萝卜焯烫2分钟，捞出沥干水分。",
      "热锅凉油，先爆香葱白段，然后放入所有食材（面筋、木耳、香菇、春笋、胡萝卜），大火快炒1分钟。",
      "倒入调好的料汁，翻炒1分钟至食材入味上色。",
      "最后倒入少许水淀粉勾芡，炒至汤汁收干浓稠，撒上葱段点缀即可出锅。"
    ]
  },
  {
    "id": "preset-006",
    "title": "Stuffed Mushrooms with Shrimp Paste",
    "zh_title": "口蘑虾滑",
    "image_key": "stuffed_mushrooms_shrimp",
    "ingredients": [
      { "en": "White Mushroom", "zh": "口蘑", "category": "Vegetable" },
      { "en": "Shrimp Paste", "zh": "虾滑", "category": "Meat" },
      { "en": "Soy Sauce", "zh": "生抽", "category": "Seasoning and herbs" },
      { "en": "Dark Soy Sauce", "zh": "老抽", "category": "Seasoning and herbs" },
      { "en": "Oyster Sauce", "zh": "蚝油", "category": "Seasoning and herbs" },
      { "en": "Sugar", "zh": "白糖", "category": "Other" },
      { "en": "Green Onion", "zh": "葱花", "category": "Vegetable" },
      { "en": "White Sesame Seeds", "zh": "白芝麻", "category": "Other" }
    ],
    "steps": [
      "口蘑去蒂洗净，将虾滑挤入并填满口蘑内部。",
      "准备酱汁：将生抽、老抽、蚝油、白糖和适量清水搅匀备用（口味重可加少许盐）。",
      "平底锅热油，先将带虾滑的一面朝下放入锅中煎制。",
      "翻面继续煎制，直到两面都呈现金黄色。",
      "倒入准备好的酱汁，盖上锅盖中小火焖煮约3分钟左右，让口蘑和虾滑充分入味。",
      "最后撒上葱花和白芝麻点缀，装盘出锅。"
    ]
  },
  {
    "id": "preset-007",
    "title": "Yuxiang Shredded Pork",
    "zh_title": "零失败鱼香肉丝",
    "image_key": "yuxiang_shredded_pork",
    "ingredients": [
      { "en": "Pork Tenderloin", "zh": "猪里脊肉", "category": "Meat" },
      { "en": "Carrot", "zh": "胡萝卜", "category": "Vegetable" },
      { "en": "Green Bell Pepper", "zh": "青椒", "category": "Vegetable" },
      { "en": "Black Fungus", "zh": "木耳", "category": "Vegetable" },
      { "en": "Garlic", "zh": "蒜", "category": "Seasoning and herbs" },
      { "en": "Ginger", "zh": "姜", "category": "Seasoning and herbs" },
      { "en": "Bean Paste", "zh": "豆瓣酱", "category": "Seasoning and herbs" },
      { "en": "Light Soy Sauce", "zh": "生抽", "category": "Seasoning and herbs" },
      { "en": "Dark Soy Sauce", "zh": "老抽", "category": "Seasoning and herbs" },
      { "en": "Vinegar", "zh": "醋", "category": "Seasoning and herbs" },
      { "en": "Sugar", "zh": "白糖", "category": "Other" },
      { "en": "Cornstarch", "zh": "淀粉", "category": "Other" }
    ],
    "steps": [
      "里脊肉切丝，用生抽、淀粉和少许油腌制10分钟；胡萝卜、青椒、泡发好的木耳切丝；蒜姜切末。",
      "调制鱼香汁：将生抽、老抽、醋、白糖、淀粉和清水混合，搅拌均匀备用。",
      "热锅凉油，放入腌好的肉丝快速翻炒至变色，盛出备用。",
      "锅中留底油，放入蒜姜末爆香，加入一勺郫县豆瓣酱炒出红油。",
      "放入胡萝卜丝、青椒丝和木耳丝翻炒至断生。",
      "将肉丝倒回锅中，倒入调好的鱼香汁，大火翻炒至汤汁浓稠，均匀裹满食材即可出锅。"
    ]
  },
  {
    "id": "preset-008",
    "title": "Stir-fried Chicken with Onions",
    "zh_title": "鸡丁炒洋葱",
    "image_key": "stir_fried_chicken_onion",
    "ingredients": [
      { "en": "Chicken Thighs", "zh": "鸡腿", "category": "Meat" },
      { "en": "Onion", "zh": "洋葱", "category": "Vegetable" },
      { "en": "Light Soy Sauce", "zh": "生抽", "category": "Seasoning and herbs" },
      { "en": "Potato Starch", "zh": "土豆淀粉", "category": "Other" },
      { "en": "Orleans Marinade", "zh": "奥尔良腌料", "category": "Seasoning and herbs" },
      { "en": "Baking Soda", "zh": "小苏打", "category": "Seasoning and herbs" },
      { "en": "Oyster Sauce", "zh": "蚝油", "category": "Seasoning and herbs" },
      { "en": "Sugar", "zh": "白糖", "category": "Other" },
      { "en": "Salt", "zh": "盐", "category": "Other" }
    ],
    "steps": [
      "鸡腿去骨留皮，去掉筋膜后切丁。",
      "腌肉：鸡丁中加入生抽、土豆淀粉、奥尔良腌料（可选）和极少量小苏打，抓匀腌制半小时。",
      "起锅烧油（油不用太多，鸡皮会出油），下鸡丁翻炒至四面焦黄、全熟后盛出备用。",
      "利用锅内底油，放入切好的洋葱丝翻炒至出香味。",
      "倒回鸡丁翻匀，加入由生抽、蚝油、白糖、盐和清水调成的碗汁。",
      "快速翻炒均匀，保留少量汤汁即可出锅。"
    ]
  },
  {
    "id": "preset-010",
    "title": "Sour and Spicy Chicken Giblets",
    "zh_title": "酸辣鸡杂",
    "image_key": "sour_spicy_chicken_giblets",
    "ingredients": [
      { "en": "Chicken Gizzard", "zh": "鸡胗", "category": "Meat" },
      { "en": "Chicken Intestine", "zh": "鸡肠", "category": "Meat" },
      { "en": "Pickled Pepper", "zh": "泡椒", "category": "Seasoning and herbs" },
      { "en": "Pickled Cowpea", "zh": "酸豆角", "category": "Vegetable" },
      { "en": "Millet Chili", "zh": "小米辣", "category": "Vegetable" },
      { "en": "Garlic Leaf", "zh": "蒜叶", "category": "Vegetable" },
      { "en": "Garlic", "zh": "大蒜", "category": "Seasoning and herbs" },
      { "en": "Ginger", "zh": "生姜", "category": "Seasoning and herbs" },
      { "en": "Rapeseed Oil", "zh": "菜籽油", "category": "Other" },
      { "en": "Light Soy Sauce", "zh": "生抽", "category": "Seasoning and herbs" },
      { "en": "Dark Soy Sauce", "zh": "老抽", "category": "Seasoning and herbs" },
      { "en": "Cooking Wine", "zh": "料酒", "category": "Seasoning and herbs" },
      { "en": "White Spirits", "zh": "白酒", "category": "Seasoning and herbs" },
      { "en": "White Pepper Powder", "zh": "白胡椒粉", "category": "Seasoning and herbs" },
      { "en": "Chicken Essence", "zh": "鸡精", "category": "Seasoning and herbs" }
    ],
    "steps": [
      "清洗鸡杂：加入少许小苏打和料酒抓洗，冲洗三遍以上确保干净。",
      "食材改刀：鸡胗切成薄片（越薄越易入味、易熟），鸡肠切小段；辣椒切圈，姜蒜切末，蒜叶切段。",
      "去腥处理：水烧至八成热下入鸡杂，加入半勺料酒焯烫后迅速捞出，沥干备用。",
      "爆香辅料：热锅倒入约20毫升菜籽油，小火爆香蒜末、泡椒、酸豆角和小米辣，转大火翻炒30秒。",
      "合炒调味：加入鸡杂，转小火依次放入老抽、生抽、白酒和白胡椒粉。",
      "快速出锅：转大火继续翻炒约20秒，最后加入蒜叶和鸡精，炒至蒜叶断生即可出锅。"
    ]
  },
  {
    "id": "preset-011",
    "title": "Braised Pork with Quail Eggs",
    "zh_title": "鹌鹑蛋红烧肉",
    "image_key": "braised_pork_quail_eggs",
    "ingredients": [
      { "en": "Pork Belly", "zh": "五花肉", "category": "Meat" },
      { "en": "Quail Eggs", "zh": "鹌鹑蛋", "category": "Meat" },
      { "en": "Ginger", "zh": "姜", "category": "Seasoning and herbs" },
      { "en": "Star Anise", "zh": "八角", "category": "Seasoning and herbs" },
      { "en": "Cinnamon", "zh": "桂皮", "category": "Seasoning and herbs" },
      { "en": "Bay Leaves", "zh": "香叶", "category": "Seasoning and herbs" },
      { "en": "Green Onion", "zh": "葱/葱花", "category": "Vegetable" },
      { "en": "Rock Sugar", "zh": "冰糖", "category": "Other" },
      { "en": "Light Soy Sauce", "zh": "生抽", "category": "Seasoning and herbs" },
      { "en": "Dark Soy Sauce", "zh": "老抽", "category": "Seasoning and herbs" },
      { "en": "Oyster Sauce", "zh": "蚝油", "category": "Seasoning and herbs" },
      { "en": "Cooking Wine", "zh": "料酒", "category": "Seasoning and herbs" },
      { "en": "Salt", "zh": "盐", "category": "Other" }
    ],
    "steps": [
      "五花肉冷水下锅，加入葱、姜片和料酒煮至变色，捞出清洗干净并切成大块。",
      "将鹌鹑蛋煮熟去壳；锅中热油，下入鹌鹑蛋煎至表面金黄、呈现“虎皮”状态后盛出。",
      "锅中留少许油，下入五花肉煸炒出多余油脂，炒至两面金黄。",
      "直接在肉中加入冰糖炒出糖色，随后放入葱、姜、八角、桂皮、香叶翻炒均匀。",
      "加入适量料酒、生抽、老抽和蚝油翻炒均匀，倒入没过食材的开水，中小火焖煮半小时。",
      "加入准备好的虎皮鹌鹑蛋继续煮15分钟，最后大火收汁，根据口味调味并撒上葱花即可。"
    ]
  },
  {
    "id": "preset-012",
    "title": "Malatang",
    "zh_title": "麻辣烫",
    "image_key": "malatang",
    "ingredients": [
      { "en": "Hotpot Soup Base", "zh": "火锅底料", "category": "Seasoning and herbs" },
      { "en": "Milk", "zh": "牛奶", "category": "Other" },
      { "en": "Sesame Paste", "zh": "芝麻酱", "category": "Other" },
      { "en": "Instant Noodles", "zh": "方便面", "category": "Other" },
      { "en": "Assorted Meatballs", "zh": "丸子", "category": "Meat" },
      { "en": "Assorted Vegetables", "zh": "蔬菜", "category": "Vegetable" },
      { "en": "Green Onion", "zh": "葱", "category": "Vegetable" },
      { "en": "Ginger", "zh": "姜", "category": "Seasoning and herbs" },
      { "en": "Garlic", "zh": "蒜", "category": "Seasoning and herbs" },
      { "en": "Light Soy Sauce", "zh": "生抽", "category": "Seasoning and herbs" },
      { "en": "Oyster Sauce", "zh": "耗油", "category": "Seasoning and herbs" },
      { "en": "Chicken Essence", "zh": "鸡精", "category": "Seasoning and herbs" }
    ],
    "steps": [
      "葱姜蒜切片备用；准备稀释好的芝麻酱：两勺芝麻酱、一勺生抽、一勺耗油、少许鸡精加水稀释开。",
      "热油倒入葱姜蒜和一小块火锅底料，小火炒出红油。",
      "加入适量清水煮开，捞出汤中的香料底渣，确保汤底清爽。",
      "倒入一盒牛奶，再次煮开。",
      "放入丸子等不容易煮熟的食材先煮，再放入青菜和面饼，继续煮2分钟左右。",
      "倒入之前准备好的芝麻酱稀释液，搅拌均匀后即可关火出锅。"
    ]
  },
  {
    "id": "preset-013",
    "title": "Wenling Stir-fried Rice Noodles",
    "zh_title": "温岭炒米面",
    "image_key": "wenling_fried_rice_noodles",
    "ingredients": [
      { "en": "Rice Noodles", "zh": "米面", "category": "Other" },
      { "en": "Egg", "zh": "鸡蛋", "category": "Meat" },
      { "en": "Cabbage", "zh": "包菜", "category": "Vegetable" },
      { "en": "Mung Bean Sprouts", "zh": "绿豆芽", "category": "Vegetable" },
      { "en": "Carrot", "zh": "胡萝卜", "category": "Vegetable" },
      { "en": "Shiitake Mushroom", "zh": "香菇", "category": "Vegetable" },
      { "en": "Dried Shrimp", "zh": "虾干", "category": "Meat" },
      { "en": "Pork", "zh": "猪肉", "category": "Meat" },
      { "en": "Onion", "zh": "洋葱", "category": "Vegetable" },
      { "en": "Green Onion", "zh": "葱", "category": "Vegetable" },
      { "en": "Ginger", "zh": "姜", "category": "Seasoning and herbs" },
      { "en": "Cooking Wine", "zh": "料酒", "category": "Seasoning and herbs" },
      { "en": "Soy Sauce", "zh": "酱油", "category": "Seasoning and herbs" },
      { "en": "Oyster Sauce (Optional)", "zh": "蚝油", "category": "Seasoning and herbs" },
      { "en": "Salt", "zh": "盐", "category": "Other" }
    ],
    "steps": [
      "准备工作：干香菇热水泡发，虾干洗净，米面用冷水提前浸泡约10分钟（切记勿用热水，防止炒制时成团）。",
      "备料：猪肉、姜切片，胡萝卜、洋葱、包心菜切丝，鸡蛋加盐搅散备用。",
      "摊蛋丝：热锅摊好鸡蛋，用锅铲直接铲成丝状盛出备用。",
      "炒制底料：重新热锅倒油，先爆香姜片，放入猪肉炒至变色，再加入虾干和香菇翻炒，沿锅边淋入料酒去腥。",
      "加入配菜：放入酱油、洋葱和胡萝卜丝继续翻炒。",
      "合炒米面：放入米面，采用双手协作法（一手筷子一手锅铲），一边翻炒一边用筷子撩起抖散，防止粘连。",
      "最后处理：依次加入包心菜、蛤蜊（可选）、绿豆芽继续抖炒至断生，最后加盐调味，放入鸡蛋丝和葱花即可出锅。"
    ]
  }
]